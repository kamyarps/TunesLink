<Application
    x:Class="TunesLinkBridge.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <Color x:Key="CanvasColor">#FF09090B</Color>
                    <Color x:Key="SurfaceColor">#FF141416</Color>
                    <Color x:Key="RaisedSurfaceColor">#FF222226</Color>
                    <Color x:Key="PrimaryTextColor">#FFF7F7FA</Color>
                    <Color x:Key="SecondaryTextColor">#FF98989F</Color>
                    <Color x:Key="SeparatorColor">#FF34343A</Color>
                    <Color x:Key="AccentTextColor">#FFFF86A3</Color>
                    <Color x:Key="SuccessColor">#FF5AD978</Color>
                    <Color x:Key="DangerColor">#FFFF6B65</Color>
                    <Color x:Key="OnBrandTextColor">#FF09090B</Color>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="CanvasColor">#FFFAFAFC</Color>
                    <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
                    <Color x:Key="RaisedSurfaceColor">#FFF1F1F5</Color>
                    <Color x:Key="PrimaryTextColor">#FF151518</Color>
                    <Color x:Key="SecondaryTextColor">#FF56565E</Color>
                    <Color x:Key="SeparatorColor">#FFD7D7DD</Color>
                    <Color x:Key="AccentTextColor">#FFB91C45</Color>
                    <Color x:Key="SuccessColor">#FF147A34</Color>
                    <Color x:Key="DangerColor">#FFB42318</Color>
                    <Color x:Key="OnBrandTextColor">#FF09090B</Color>
                </ResourceDictionary>
                <ResourceDictionary x:Key="HighContrast">
                    <StaticResource x:Key="CanvasColor" ResourceKey="SystemColorWindowColor" />
                    <StaticResource x:Key="SurfaceColor" ResourceKey="SystemColorWindowColor" />
                    <StaticResource x:Key="RaisedSurfaceColor" ResourceKey="SystemColorWindowColor" />
                    <StaticResource x:Key="PrimaryTextColor" ResourceKey="SystemColorWindowTextColor" />
                    <StaticResource x:Key="SecondaryTextColor" ResourceKey="SystemColorWindowTextColor" />
                    <StaticResource x:Key="SeparatorColor" ResourceKey="SystemColorWindowTextColor" />
                    <StaticResource x:Key="AccentTextColor" ResourceKey="SystemColorHighlightColor" />
                    <StaticResource x:Key="SuccessColor" ResourceKey="SystemColorWindowTextColor" />
                    <StaticResource x:Key="DangerColor" ResourceKey="SystemColorWindowTextColor" />
                    <Color x:Key="OnBrandTextColor">#FF09090B</Color>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <SolidColorBrush x:Key="CanvasBrush" Color="{ThemeResource CanvasColor}" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="{ThemeResource SurfaceColor}" />
            <SolidColorBrush x:Key="RaisedSurfaceBrush" Color="{ThemeResource RaisedSurfaceColor}" />
            <SolidColorBrush x:Key="PrimaryTextBrush" Color="{ThemeResource PrimaryTextColor}" />
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="{ThemeResource SecondaryTextColor}" />
            <SolidColorBrush x:Key="SeparatorBrush" Color="{ThemeResource SeparatorColor}" />
            <SolidColorBrush x:Key="AccentTextBrush" Color="{ThemeResource AccentTextColor}" />
            <SolidColorBrush x:Key="SuccessBrush" Color="{ThemeResource SuccessColor}" />
            <SolidColorBrush x:Key="DangerBrush" Color="{ThemeResource DangerColor}" />
            <SolidColorBrush x:Key="OnBrandTextBrush" Color="{ThemeResource OnBrandTextColor}" />
            <LinearGradientBrush x:Key="BrandBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFFF5B84" Offset="0" />
                <GradientStop Color="#FFB69CFF" Offset="1" />
            </LinearGradientBrush>

            <Style x:Key="PageTitleStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Segoe UI Variable Display" />
                <Setter Property="FontSize" Value="28" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="LineHeight" Value="34" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="Foreground" Value="{ThemeResource PrimaryTextBrush}" />
            </Style>
            <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Segoe UI Variable Display" />
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="LineHeight" Value="25" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="Foreground" Value="{ThemeResource PrimaryTextBrush}" />
            </Style>
            <Style x:Key="BodyStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="LineHeight" Value="22" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="Foreground" Value="{ThemeResource PrimaryTextBrush}" />
            </Style>
            <Style x:Key="SecondaryStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="LineHeight" Value="20" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="Foreground" Value="{ThemeResource SecondaryTextBrush}" />
            </Style>
            <Style x:Key="TonalButtonStyle" TargetType="Button">
                <Setter Property="MinHeight" Value="44" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="Background" Value="{ThemeResource RaisedSurfaceBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource SeparatorBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Foreground" Value="{ThemeResource PrimaryTextBrush}" />
            </Style>
            <Style x:Key="TonalToggleButtonStyle" TargetType="ToggleButton">
                <Setter Property="MinHeight" Value="44" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="Padding" Value="14,8" />
                <Setter Property="Background" Value="{ThemeResource RaisedSurfaceBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource SeparatorBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Foreground" Value="{ThemeResource PrimaryTextBrush}" />
            </Style>
            <Style x:Key="PrimaryToggleButtonStyle" TargetType="ToggleButton"
                   BasedOn="{StaticResource TonalToggleButtonStyle}">
                <Setter Property="Background" Value="{StaticResource BrandBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Foreground" Value="{ThemeResource OnBrandTextBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>
            <Style x:Key="IconButtonStyle" TargetType="Button"
                   BasedOn="{StaticResource TonalButtonStyle}">
                <Setter Property="MinWidth" Value="44" />
                <Setter Property="Width" Value="44" />
                <Setter Property="Padding" Value="10" />
            </Style>
            <Style x:Key="SettingsFlyoutPresenterStyle" TargetType="FlyoutPresenter">
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="Padding" Value="20" />
                <Setter Property="Background" Value="{ThemeResource SurfaceBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource SeparatorBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>
            <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource TonalButtonStyle}">
                <Setter Property="Foreground" Value="{ThemeResource DangerBrush}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
